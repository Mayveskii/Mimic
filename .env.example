# Mimic MCP Server — Environment Configuration
#
# Copy this file to .env and adjust values for your deployment.
# All ports use 1337-style numbering (leet speak aesthetic).

# ============================================================================
# CORE SERVER
# ============================================================================

# Primary MCP server port (stdio/SSE/HTTP)
# Default: 1337
MIMIC_PORT=1337

# HTTP API and Prometheus metrics port
# Default: 1117
MIMIC_HTTP_PORT=1117

# Admin/management API port
# Default: 1227
MIMIC_ADMIN_PORT=1227

# WebSocket transport port
# Default: 1447
MIMIC_WS_PORT=1447

# Internal mesh node communication (future)
# Default: 1557
MIMIC_MESH_PORT=1557

# Log level: debug, info, warn, error
MIMIC_LOG_LEVEL=info

# ============================================================================
# BUDGET & LIMITS
# ============================================================================

# Maximum tokens per session (prevents runaway costs)
MIMIC_BUDGET_TOKENS=100000

# Maximum time per session in milliseconds (1 hour)
MIMIC_BUDGET_TIME_MS=3600000

# Maximum concurrent tasks
MIMIC_MAX_TASKS=50

# ============================================================================
# RTK COMPRESSION
# ============================================================================

# Enable output compression (reduces tokens by 90%+)
MIMIC_RTK_ENABLED=true

# Max lines to keep for head+tail truncation (0 = disable)
MIMIC_RTK_MAX_LINES=100

# Strip ANSI escape codes from output
MIMIC_RTK_STRIP_ANSI=true

# Collapse consecutive blank lines
MIMIC_RTK_COLLAPSE_BLANKS=true

# ============================================================================
# DEEP CACHE (future: mesh hub)
# ============================================================================

# Enable local deep cache for pattern lookup
MIMIC_CACHE_ENABLED=true

# Path to cache directory
MIMIC_CACHE_DIR=/var/lib/mimic/cache

# Minimum survival index for cached patterns (0.0-1.0)
MIMIC_CACHE_MIN_SI=0.8

# Maximum cache size in MB
MIMIC_CACHE_MAX_SIZE_MB=1024

# ============================================================================
# SECURITY
# ============================================================================

# Require explicit confirmation for dangerous operations
MIMIC_CONFIRM_DANGEROUS=true

# Circuit breaker: max consecutive denials before cooldown
MIMIC_CIRCUIT_BREAKER_THRESHOLD=3

# Cooldown period after circuit breaker trips (seconds)
MIMIC_CIRCUIT_BREAKER_COOLDOWN=60

# ============================================================================
# MESH (future: distributed knowledge)
# ============================================================================

# Mesh hub endpoint (empty = standalone mode)
# MIMIC_MESH_HUB=https://mesh.mimic.dev

# Node ID (auto-generated if empty)
# MIMIC_NODE_ID=

# Reputation token (obtained from mesh hub)
# MIMIC_MESH_TOKEN=

# Domains to share with mesh (comma-separated, empty = none)
# MIMIC_MESH_SHARE_DOMAINS=error_handling,config,testing

# Domains to request from mesh (comma-separated, empty = all)
# MIMIC_MESH_REQUEST_DOMAINS=
